    {
      "parameters": {
        "jsCode": "const item = $input.item;\nconst csvBase64 = item.json.csv;\nconst email = $('Prepare Variables').item.json.email;\n\nconst binaryData = await this.helpers.prepareBinaryData(\n  Buffer.from(csvBase64, 'base64'),\n  'competitor-faqs.csv',\n  'text/csv'\n);\n\nreturn [{\n  json: { email },\n  binary: { 'competitor-faqs': binaryData }\n}];"
      },
